# ── Port ───────────────────────────────────────────────────────
PORT=8123

# ── Security ────────────────────────────────────────────────────
# Admin password (only effective on first start)
ADMIN_PASSWORD=ChangeMe!

# ── Database Encryption ──────────────────────────────────────────
# Optional: encrypt the SQLite database with SQLCipher (AES-256).
# Generate a key: openssl rand -hex 32
# IMPORTANT: Set this BEFORE first start. Cannot be changed afterwards without a fresh DB.
# DB_KEY=
